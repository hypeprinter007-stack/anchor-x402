# anchor-x402 runtime config
#
# Copy to .env, fill in the values, and run with:
#   sam build && sam deploy --guided   (production)
#   uvicorn app:app --reload           (local — won't hit mainnet)
#
# Treasury wallets receive x402 inbound payments AND pay anchor tx fees.
# Generate fresh keys per env. NEVER commit .env or echo these values
# anywhere they might be logged.

# --- Base (EVM) treasury ---
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=

# --- Solana treasury ---
# Required if you want to accept Solana USDC inbound AND/OR anchor on Solana.
# pay.sh submission requires this — pay-skills enforces Solana USDC support.
SOLANA_TREASURY_ADDRESS=
SOLANA_TREASURY_KEY=

# --- Polygon JPYC rail (optional) ---
# Enables ¥-denominated payments on Polygon via JPYC v2 (Japan's first FSA-
# licensed yen stablecoin). Both values below auto-fall-back to the Base
# treasury — Ethereum addresses are universal across EVM chains, so the
# same EOA can hold POL for gas and JPYC for receipts. Leave both empty for
# single-wallet mode (just send POL to your Base TREASURY_ADDRESS on Polygon).
# Set them only when running a dedicated Polygon EOA.
POLYGON_TREASURY_ADDRESS=
POLYGON_RELAYER_KEY=
# POLYGON_RPC_URL=https://polygon-rpc.com    # override if public node rate-limits

# --- CDP facilitator (Coinbase) ---
# Get these from https://portal.cdp.coinbase.com — the JWT key id is non-sensitive,
# the secret is base64-encoded ed25519 private bytes.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- RPC endpoints (override if you have private RPCs; defaults are public) ---
# BASE_RPC_URL=https://mainnet.base.org
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Divigent treasury intelligence (optional) ---
# v2 architecture: a Node intelligence Lambda wraps @divigent/sdk's
# read-only assessLiquidity() and returns JSON decisions; a Python
# execution Lambda signs and broadcasts deposit/withdraw via operator
# delegation. Treasury private key never enters Lambda; Divigent's
# intelligence math stays compiled inside their SDK.
#
# Setup flow:
#   1. .venv/bin/python scripts/divigent_setup.py generate-operator
#   2. Fund operator with ~0.001 ETH on Base
#   3. bootstrap-treasury <operator-address>  (signs initialize, setOperator, approve)
#   4. Set DIVIGENT_ENABLED=true, pass DivigentOperatorPrivateKey on next deploy.
#
# Cron Lambdas short-circuit safely when DIVIGENT_ENABLED=false.
DIVIGENT_ENABLED=false
DIVIGENT_OPERATOR_PRIVATE_KEY=

# Policy context passed to assessLiquidity(). Defaults below are tuned
# for anchor's treasury shape (small gas-only outflows, no scheduled
# payouts) — overridden via CFN params on deploy, env vars locally.
# All atomic-unit values are USDC at 6 decimals (5000000 = 5 USDC).
# DIVIGENT_MIN_OPERATING_BALANCE=5000000
# DIVIGENT_UPCOMING_PAYOUTS=0
# DIVIGENT_MAX_DEPLOYABLE_PERCENT=95
# riskPreference: 'conservative' | 'balanced' | 'capital-efficient'
# DIVIGENT_RISK_PREFERENCE=conservative
# Slippage tolerance on previewDeposit / previewWithdrawNet (basis points).
# DIVIGENT_SLIPPAGE_BPS=50
