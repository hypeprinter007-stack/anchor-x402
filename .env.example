# anchor-x402 runtime config
#
# Copy to .env, fill in the values, and run with:
#   sam build && sam deploy --guided   (production)
#   uvicorn app:app --reload           (local — won't hit mainnet)
#
# Treasury wallets receive x402 inbound payments AND pay anchor tx fees.
# Generate fresh keys per env. NEVER commit .env or echo these values
# anywhere they might be logged.

# --- Base (EVM) treasury ---
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=

# --- Solana treasury ---
# Required if you want to accept Solana USDC inbound AND/OR anchor on Solana.
# pay.sh submission requires this — pay-skills enforces Solana USDC support.
SOLANA_TREASURY_ADDRESS=
SOLANA_TREASURY_KEY=

# --- CDP facilitator (Coinbase) ---
# Get these from https://portal.cdp.coinbase.com — the JWT key id is non-sensitive,
# the secret is base64-encoded ed25519 private bytes.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- RPC endpoints (override if you have private RPCs; defaults are public) ---
# BASE_RPC_URL=https://mainnet.base.org
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
