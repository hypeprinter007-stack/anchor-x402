{
  "name": "anchor-x402-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Circle Gateway x402 facade over api.anchor-x402.com. Node Lambda; bundled with esbuild.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "esbuild src/handler.js --bundle --platform=node --target=node22 --format=cjs --outfile=dist/handler.js",
    "start": "LOCAL=1 node src/handler.js"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
    "@x402/core": "^2.0.0",
    "@x402/evm": "^2.0.0",
    "express": "^4.21.0",
    "serverless-http": "^3.2.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
